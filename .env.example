# Database (Railway PostgreSQL or local)
DATABASE_URL=postgresql://pipelineiq:pipelineiq_secret@localhost:5432/pipelineiq

# JWT Secret - generate a strong random string for production
SECRET_KEY=change-me-to-a-long-random-secret-string-in-production
ACCESS_TOKEN_EXPIRE_HOURS=8

# Backend URL (used by Streamlit frontend)
BACKEND_URL=http://localhost:8000

# Initial admin user (created by seed.py)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@hardwaredirect.com.au
ADMIN_PASSWORD=admin123
